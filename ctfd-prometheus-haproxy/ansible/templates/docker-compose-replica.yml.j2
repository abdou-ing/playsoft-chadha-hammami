version: '3.8'
services:
  mariadb-replica:
    image: mariadb:10.5
    container_name: ctfd_db_replica
    restart: always
    environment:
      MYSQL_ROOT_PASSWORD: {{ mariadb_root_password }}
      MYSQL_DATABASE: {{ mariadb_database }}
    volumes:
      - replica_data:/var/lib/mysql
      - ./mariadb-replica.cnf:/etc/mysql/conf.d/mariadb-replica.cnf
      - ./init-replica.sql:/docker-entrypoint-initdb.d/init-replica.sql
    ports:
      - "3308:3306"

volumes:
  replica_data:
