[metasploitable]
#msf1 ansible_host=10.0.30.47 ansible_user=msfadmin ansible_ssh_private_key_file=/home/ansible/.ssh/id_rsa
#msf1 ansible_host=10.0.30.47 ansible_user=user ansible_password=user ansible_ssh_private_key_file=/home/ansible/.ssh/id_rsa
msf1 ansible_host=10.0.30.47 ansible_user=msfadmin ansible_password=msfadmin ansible_become=false ansible_python_interpreter=/bin/false

[metasploitable:vars]
ansible_ssh_common_args='-o HostkeyAlgorithms=+ssh-rsa -o PubkeyAcceptedKeyTypes=+ssh-rsa'

[kali]
kali1 ansible_host=10.0.30.65 ansible_user=bob ansible_ssh_private_key_file=/home/ansible/.ssh/id_ed25519

[ctfd]
ctfd1 ansible_host=10.0.30.66 ansible_user=ctfd ansible_ssh_private_key_file=/home/ansible/.ssh/id_rsa

